@using Desk.Constants

@inject Desk.Contracts.Services.IUserService UserService

@model Desk.Models.SpecialPropertiesViewModel

@{
	Layout = "~/Views/Shared/_Layout.cshtml";

	ViewData["Title"] = "Új Jegy";
}

<div class="row">
	<div class="col-9 ">
		<form asp-action="Create">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			@if (UserService.IsDevUser(User.Identity?.Name) || User.IsInRole(Dictionaries.Role["ADMIN_ROLE"]))
			{
				<div class="@Styles.CreateRow">
					<div class="@Styles.CreateLeftColumn">
						<label asp-for="Ticket!.ReportedById" class="control-label"></label>
					</div>
					<div class="@Styles.CreateRightColumn">
						<select asp-for="Ticket!.ReportedById" class="form-select w-50" asp-items="ViewBag.Users">
							<option value="@ViewBag.LoggedInUser.Id" selected>@ViewBag.LoggedInUser.FullName</option>
						</select>
					</div>
				</div>
			}
			<div class="@Styles.CreateRow">
				<div class="@Styles.CreateLeftColumn">
					@Html.DisplayNameFor(model => model.Ticket!.Priority)
				</div>
				<div class="@Styles.CreateRightColumn">
					@foreach (var item in Dictionaries.TicketPriority)
					{
						<input type="radio" class="btn-check btn-primary" name="Ticket.Priority" id="@item.Key" value="@item.Key" autocomplete="off" @(item.Key == Dictionaries.TicketPriority.Keys.First() ? "checked" : "")>
						<label class="btn" for="@item.Key">@item.Value</label>
					}
				</div>
			</div>

			@* Special Properties *@
			@RenderSection("SpecialProperty", required: false)

			@* Description *@
			<div class="@Styles.CreateRow">
				<div class="@Styles.CreateLeftColumn">
					<label asp-for="Ticket!.Description" class="control-label">Megjegyzés</label>
				</div>
				<div class="@Styles.CreateRightColumn">
					<input asp-for="Ticket!.Description" class="form-control" />
					<span asp-validation-for="Ticket!.Description" class="text-danger"></span>
				</div>
			</div>

			<div class="row mb-4">
				<div class="">
					<div class="form-group">
						<button type="submit" value="Létrehoz" class="btn btn-primary me-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-floppy2-fill me-1" viewBox="0 0 16 16">
								<path d="M12 2h-2v3h2z" />
								<path d="M1.5 0A1.5 1.5 0 0 0 0 1.5v13A1.5 1.5 0 0 0 1.5 16h13a1.5 1.5 0 0 0 1.5-1.5V2.914a1.5 1.5 0 0 0-.44-1.06L14.147.439A1.5 1.5 0 0 0 13.086 0zM4 6a1 1 0 0 1-1-1V1h10v4a1 1 0 0 1-1 1zM3 9h10a1 1 0 0 1 1 1v5H2v-5a1 1 0 0 1 1-1" />
							</svg>
							Létrehoz
						</button> |
						<a asp-controller="Tickets" asp-action="Index" class="ms-2"> Vissza a listához</a>
					</div>
				</div>
				<div class="">
				</div>
			</div>

		</form>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
