@model ErrorViewModel
@{
    ViewData["Title"] = "Hiba";
}

<h1 class="text-danger">Upsz! :(</h1>
<h2 class="text-danger">Sajnos történt valami.</h2>

@if (Model.ShowRequestId)
{
    <p class="mt-3">
        <a href="mailto:email?subject=Hiba&body=Hiba azonosító: @Model.RequestId" >
            [ Hiba jelzése a supportnak ]
        </a>
    </p>
}


