@model ErrorViewModel
@{
    ViewData["Title"] = "Hiba";
}

<h1 class="text-danger">Upsz! :(</h1>
@* <h2 class="text-danger">Sajnos történt valami.</h2> *@
<p>@ViewBag.ErrorMessage</p>

@if (Model.ShowRequestId)
{
    <p class="mt-3">
        <a href="mailto:test@test.test?subject=Hiba az oldalon&body=Hiba azonosító: @Model.RequestId" >
            [ Hiba jelzése a supportnak ]
        </a>
    </p>
}



