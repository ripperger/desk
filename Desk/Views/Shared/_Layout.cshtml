@using Desk.Models;
@using Desk.Constants;

@inject Desk.Contracts.Services.IUserService UserService

@{
	var currentPath = ViewContext.HttpContext.Request.Path.ToString();

	string SidebarStyle(string path)
	{
		return "list-group-item list-group-item-action fw-medium " +
			(currentPath.StartsWith(path) ? "border-2 border-primary" : "opacity-75 border-0");
	}

	string NavbarStyle(string path)
	{
		return "list-group list-group-item list-group-item-action fw-medium text-capitalize " +
			(currentPath.StartsWith(path) ? "border-2 border-primary" : "opacity-75 border-0");
	}

	// Updating LastLogin property
	await UserService.Login(UserService.GetUserByUserName(UserService.LoggedInUserName(User)));
}

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - desk</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/Desk.styles.css" asp-append-version="true" />

	<link rel="stylesheet" href="~/css/bootstrap.cosmo.min.css" />
	<link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/toastr.min.css" asp-append-version="true" />

	<link href="~/favicon.ico" rel="icon" sizes="32x32">

	@RenderSection("Head", required: false)


</head>
<body>
	@if (TempData["success"] != null || TempData["error"] != null)
	{
		<partial name="_Notification" />
	}

	<div class=" sticky-top">
		<header class="">
			<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white mb-3 ps-3 pe-3">
				<div class="container-fluid">
					<a class="navbar-brand nav-item" asp-controller="Home" asp-action="Index"><span class="text-logo-start">police</span><span class="text-logo-end">desk</span></a>
					<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
						<ul class="navbar-nav flex-grow-1 ">
							<li class="nav-item">
								<a class="@NavbarStyle("/Tickets")" asp-area="" asp-controller="Tickets" asp-action="Index">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-card-list" viewBox="0 0 16 16">
										<path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2z" />
										<path d="M5 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 5 8m0-2.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5m0 5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5m-1-5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0M4 8a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0m0 2.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0" />
									</svg>
									jegylista
								</a>
							</li>
							@if (UserService.IsDevUser(User) || User.IsInRole(Dictionaries.Role["ADMIN_ROLE"]))
							{
								<li class="nav-item">
									<a class="@NavbarStyle("/Users")" asp-area="" asp-controller="Users" asp-action="Index">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-people" viewBox="0 0 16 16">
											<path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4" />
										</svg>
										személyek
									</a>
								</li>
								<li class="nav-item">
									<a class="@NavbarStyle("/Suppliers")" asp-area="" asp-controller="Suppliers" asp-action="Index">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-truck" viewBox="0 0 16 16">
											<path d="M0 3.5A1.5 1.5 0 0 1 1.5 2h9A1.5 1.5 0 0 1 12 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V10.5a1.5 1.5 0 0 1-1.5 1.5H14a2 2 0 1 1-4 0H5a2 2 0 1 1-3.998-.085A1.5 1.5 0 0 1 0 10.5zm1.294 7.456A2 2 0 0 1 4.732 11h5.536a2 2 0 0 1 .732-.732V3.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v7a.5.5 0 0 0 .294.456M12 10a2 2 0 0 1 1.732 1h.768a.5.5 0 0 0 .5-.5V8.35a.5.5 0 0 0-.11-.312l-1.48-1.85A.5.5 0 0 0 13.02 6H12zm-9 1a1 1 0 1 0 0 2 1 1 0 0 0 0-2m9 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2" />
										</svg>
										beszállítók
									</a>
								</li>
								<li class="nav-item">
									<a class=" @NavbarStyle("/Groups")" asp-area="" asp-controller="Groups" asp-action="Index">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-collection" viewBox="0 0 16 16">
											<path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6zm1.5.5A.5.5 0 0 1 1 13V6a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5z" />
										</svg>
										csoportok
									</a>
								</li>
								<li class="nav-item">
									<a class="@NavbarStyle("/ADUsers")" asp-area="" asp-controller="ADUsers" asp-action="Index">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-people" viewBox="0 0 16 16">
											<path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4" />
										</svg>
										AD userek
									</a>
								</li>
								<li class="nav-item">
									<a class="@NavbarStyle("/Csv/ImportCsv")" asp-area="" asp-controller="Csv" asp-action="ImportCsv">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-plus" viewBox="0 0 16 16">
											<path d="M8.5 6a.5.5 0 0 0-1 0v1.5H6a.5.5 0 0 0 0 1h1.5V10a.5.5 0 0 0 1 0V8.5H10a.5.5 0 0 0 0-1H8.5z" />
											<path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2zm10-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1" />
										</svg>
										import
									</a>
								</li>
								<li class="nav-item">
									<a class="@NavbarStyle("/Error")" asp-area="" asp-controller="Error" asp-action="Error">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-bug" viewBox="0 0 16 16">
											<path d="M4.355.522a.5.5 0 0 1 .623.333l.291.956A5 5 0 0 1 8 1c1.007 0 1.946.298 2.731.811l.29-.956a.5.5 0 1 1 .957.29l-.41 1.352A5 5 0 0 1 13 6h.5a.5.5 0 0 0 .5-.5V5a.5.5 0 0 1 1 0v.5A1.5 1.5 0 0 1 13.5 7H13v1h1.5a.5.5 0 0 1 0 1H13v1h.5a1.5 1.5 0 0 1 1.5 1.5v.5a.5.5 0 1 1-1 0v-.5a.5.5 0 0 0-.5-.5H13a5 5 0 0 1-10 0h-.5a.5.5 0 0 0-.5.5v.5a.5.5 0 1 1-1 0v-.5A1.5 1.5 0 0 1 2.5 10H3V9H1.5a.5.5 0 0 1 0-1H3V7h-.5A1.5 1.5 0 0 1 1 5.5V5a.5.5 0 0 1 1 0v.5a.5.5 0 0 0 .5.5H3c0-1.364.547-2.601 1.432-3.503l-.41-1.352a.5.5 0 0 1 .333-.623M4 7v4a4 4 0 0 0 3.5 3.97V7zm4.5 0v7.97A4 4 0 0 0 12 11V7zM12 6a4 4 0 0 0-1.334-2.982A3.98 3.98 0 0 0 8 2a3.98 3.98 0 0 0-2.667 1.018A4 4 0 0 0 4 6z" />
										</svg>
										error page
									</a>
								</li>
							}
							@if (UserService.IsDevUser(User) || User.IsInRole(Dictionaries.Role["ADMIN_ROLE"]) || User.IsInRole(Dictionaries.Role["REPORTS_ROLE"]))
							{
								<li class="nav-item">
									<a class="@NavbarStyle("/Reports")" asp-area="" asp-controller="Reports" asp-action="Index">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-graph-up-arrow" viewBox="0 0 16 16">
											<path fill-rule="evenodd" d="M0 0h1v15h15v1H0zm10 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V4.9l-3.613 4.417a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61L13.445 4H10.5a.5.5 0 0 1-.5-.5" />
										</svg>
										riportok
									</a>
								</li>
							}
						</ul>
						<ul class="navbar-nav text-dark mt-1">
							<li class="nav-item"><span class="text-logo-start">üdv, </span><span class="text-logo-end">@UserService.GetUserByUserName(UserService.LoggedInUserName(User)).FullName</span>!</li>
						</ul>
					</div>
				</div>
			</nav>
		</header>
	</div>

	<div class="row me-2 mt-4 ms-1">

		@* Sidebar *@
		<div class="col-auto list-group ms-4">
			@*  mt-2 *@
			@RenderSection("Sidebar", required: false)

			<div class="fw-normal opacity-75 ps-1 mb-1">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
					<path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2" />
				</svg>
				Új jegyek
			</div>
			<div class="fw-lighter opacity-50 ps-1 list-group-item border-0">Jogosultságok</div>

			@* New Password *@
			<a asp-controller="NewPassword" asp-action="Create" class="@SidebarStyle("/NewPassword")">@Dictionaries.Category["NewPassword"]</a>
			

			<div class="fw-lighter opacity-50 ps-1 list-group-item border-0">Eszköz bejelentő</div>
			<div class="fw-lighter opacity-50 ps-2 list-group-item border-0">Multifunkcionális eszközök</div>

			@* Konica Minolta *@
			<a asp-controller="KonicaMinolta" asp-action="Create" class="@SidebarStyle("/KonicaMinolta")">Konica Minolta</a>

			@* Xerox *@
			<a asp-controller="Xerox" asp-action="Create" class="@SidebarStyle("/Xerox")">Xerox</a>

			@* <a href="#" class="list-group-item list-group-item-action border-0 fw-medium ">Link item</a> *@

		</div>

		<div class="col ms-4 me-4">
			<div class="">
				@* ps-3 pe-3 *@
				@RenderSection("Header", required: false)
			</div>

			<main role="main" class="">
				@RenderBody()
			</main>
		</div>

	</div>


	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>

	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
