{

    "ConnectionStrings": {
        "SqliteLocalConnection": "Data Source=Data\\test_desk.db"
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File",
            "Serilog.Enrichers.Environment"
        ],
        "Enrich": [
            "FromLogContext",
            "WithEnvironmentUserName"
        ],
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/log.txt",
                    "rollingInterval": "Day",
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {ClientIp} {UserName} {Message:lj}{NewLine}{Exception}"
                }
            }
        ]
    }

}
