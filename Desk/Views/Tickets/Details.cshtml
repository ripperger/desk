@using Desk.Constants

@model Desk.Models.Ticket

@{
    ViewData["Title"] = "Details";

    string design = "mb-4 p-2 border border-1 border-secondary";
}

@* <h1>Details</h1> *@

<div>
    <div>
        <span class="fw-bold">@Model.ReferenceId()</span>
        <span class="ms-4 me-4">
            @Helper.FormatCategory(Model.Categorization!)
        </span>

        <a asp-action="Edit" asp-route-id="@Model?.Id">Szerkesztés</a> |
        <a asp-action="Index">Vissza a listához</a>

    </div>

    <hr />

    <div class="container">
        <div class="row">
            <div class="col-4">

                @* User (Created by) details *@
                @if (Model!.CreatedById != Model.ReportedById)
                {
                    <div class="@design">
                        <div class="fw-bold">
                            @Html.DisplayNameFor(model => model.CreatedBy):
                        </div>
                        <div>
                            @Html.DisplayFor(model => model.CreatedBy!.FullName)
                            @* (@Html.DisplayFor(model => model.CreatedBy!.UserName)) *@
                        </div>
                    </div>
                    @* <hr /> *@
                }

                @* User (Reported by) details *@
                <div class="@design">
                    <div class="fw-bold">
                        @Html.DisplayNameFor(model => model.ReportedBy):
                    </div>
                    <div>
                        @Html.DisplayFor(model => model.ReportedBy!.FullName)
                        (@Html.DisplayFor(model => model.ReportedBy!.UserName))
                    </div>
                    <div>@Html.DisplayFor(model => model.ReportedBy!.Department)</div>
                    <div>@Html.DisplayFor(model => model.ReportedBy!.Phone)</div>
                    <div>@Html.DisplayFor(model => model.ReportedBy!.Email)</div>
                </div>
                @*                 <hr /> *@

                @* Device details *@
                <div class="@design">
                    <div class="fw-bold">
                        Eszköz:
                    </div>
                </div>
                @*                 <hr /> *@

                @* Ticket details *@
                <div class="@design">
                    <div class="row">
                        <div class="fw-bold col-6">
                            @Html.DisplayNameFor(model => model.Timestamp):
                        </div>
                        <div class="col-6">
                            @Html.DisplayFor(model => model.Timestamp)
                        </div>
                    </div>
                    <div class="row">
                        <div class="fw-bold col-6">
                            @Html.DisplayNameFor(model => model.Status):
                        </div>
                        <div class="col-6">
                            @Dictionaries.TicketStatus[Model.Status]
                        </div>
                    </div>
                    <div class="row">
                        <div class="fw-bold col-6">
                            @Html.DisplayNameFor(model => model.Priority):
                        </div>
                        <div class="col-6">
                            @Dictionaries.TicketPriority[Model.Priority]
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-8">

                @* Description *@
                <div class="@design">
                    <div class="fw-bold">
                        @Html.DisplayNameFor(model => model.Description):
                    </div>
                    <div>@Model.Description</div>
                </div>

                @* Attachments *@
                <div class="@design">
                    <div class="fw-bold">
                        Mellékletek:
                    </div>
                </div>

                @* Comments and Events *@
                <div class="@design">
                    <div class="fw-bold">
                        Hozzászólások és Események:
                    </div>
                </div>

            </div>

        </div>

    </div>
